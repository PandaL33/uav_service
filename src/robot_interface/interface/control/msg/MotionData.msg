# 姿态四元数
Quaternion quaternion

# 姿态欧拉角 [roll, pitch, yaw]
EulerAngle rpy

# 机器狗加速度
Vector3 body_acc

# 机器狗角速度
Vector3 body_gyro

# 上电原点坐标系位置
Vector3 position

# 上电原点坐标系移动速度
Vector3 world_velocity

# 自身移动速度
Vector3 body_velocity

# 关节角度
JointData joint_angle

# 关节角速度
JointData joint_velocity

# 关节扭矩
JointData joint_torque