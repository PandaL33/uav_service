[Unit]
Description=ROS2 Multi Algorithm Manager Service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/public/lgl/ros2_ws

Environment="ROS_DOMAIN_ID=0"
Environment="ROS_LOCALHOST_ONLY=0"
Environment="ROS_LOG_DIR=/public/lgl/ros2_ws/logs"
Environment="PYTHONPATH=/home/lgl/.local/lib/python3.8/site-packages"

# 创建日志目录
ExecStartPre=/bin/mkdir -p /public/lgl/ros2_ws/logs

# 启动 ROS2 节点，日志同时输出到 journal 和文件
ExecStart=/bin/bash -lc "source /opt/ros/galactic/setup.bash && source install/setup.bash && ros2 launch multi_algo_manager multi_algo_manager.launch.py | tee -a /public/lgl/ros2_ws/logs/multi_algo_manager.log"

Restart=always
RestartSec=5
StandardOutput=journal+console
StandardError=journal+console

# 日志清理
ExecStartPost=/bin/bash -c "find /public/lgl/ros2_ws/logs -name '*.log' -size +100M -delete && find /public/lgl/ros2_ws/logs -name '*.log.*' -mtime +7 -delete"

[Install]
WantedBy=multi-user.target